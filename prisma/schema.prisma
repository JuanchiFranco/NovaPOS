// Esquema de base de datos - Inventario y Ventas
// SQLite local, offline-first

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Seguridad / Auditoría (esquema listo desde fase 1; login se activa en fase 2)
// ---------------------------------------------------------------------------

model Rol {
  id          Int        @id @default(autoincrement())
  nombre      String     @unique
  descripcion String?
  permisos    String // JSON serializado de permisos por módulo
  usuarios    Usuario[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("roles")
}

model Usuario {
  id           Int       @id @default(autoincrement())
  nombre       String
  usuario      String    @unique
  passwordHash String
  activo       Boolean   @default(true)
  rolId        Int
  rol          Rol       @relation(fields: [rolId], references: [id])
  ventas       Venta[]
  auditorias   Auditoria[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("usuarios")
}

model Auditoria {
  id         Int       @id @default(autoincrement())
  entidad    String // p.ej. "venta", "producto", "cliente"
  entidadId  Int
  accion     String // CREATE | UPDATE | DELETE
  detalle    String? // JSON con el diff / detalle
  usuarioId  Int?
  usuario    Usuario?  @relation(fields: [usuarioId], references: [id])
  createdAt  DateTime  @default(now())

  @@index([entidad, entidadId])
  @@map("auditoria")
}

// ---------------------------------------------------------------------------
// Configuración del negocio (registro único)
// ---------------------------------------------------------------------------

model Configuracion {
  id                 Int      @id @default(autoincrement())
  nombreComercial    String   @default("VARIEDADES J&A")
  eslogan            String?
  mensajePie         String?
  nit                String?
  direccion          String?
  telefono           String?
  correo             String?
  logoPath           String?
  porcentajeIva      Float    @default(19)
  moneda             String   @default("COP")
  simboloMoneda      String   @default("$")
  prefijoFactura     String   @default("FAC")
  numeroInicialFactura Int    @default(1)
  siguienteNumeroFactura Int  @default(1)
  impresoraPredeterminada String?
  updatedAt          DateTime @updatedAt

  @@map("configuracion")
}

// ---------------------------------------------------------------------------
// Clientes
// ---------------------------------------------------------------------------

model Cliente {
  id            Int      @id @default(autoincrement())
  nombre        String
  documento     String?  @unique
  telefono      String?
  direccion     String?
  correo        String?
  observaciones String?
  activo        Boolean  @default(true)
  ventas        Venta[]
  facturas      Factura[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([nombre])
  @@index([telefono])
  @@map("clientes")
}

// ---------------------------------------------------------------------------
// Productos e inventario
// ---------------------------------------------------------------------------

model Categoria {
  id        Int       @id @default(autoincrement())
  nombre    String    @unique
  productos Producto[]

  @@map("categorias")
}

model Producto {
  id             Int       @id @default(autoincrement())
  codigo         String    @unique
  nombre         String
  categoriaId    Int?
  categoria      Categoria? @relation(fields: [categoriaId], references: [id])
  precioCompra   Float     @default(0)
  precioVenta    Float
  stock          Int       @default(0)
  stockMinimo    Int       @default(5)
  descripcion    String?
  activo         Boolean   @default(true)
  detalleVentas  DetalleVenta[]
  movimientos    MovimientoInventario[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([nombre])
  @@index([codigo])
  @@map("productos")
}

model MovimientoInventario {
  id          Int             @id @default(autoincrement())
  productoId  Int
  producto    Producto        @relation(fields: [productoId], references: [id])
  tipo        String // ENTRADA | SALIDA | AJUSTE
  cantidad    Int
  stockAnterior Int
  stockNuevo  Int
  motivo      String?
  ventaId     Int?
  venta       Venta?          @relation(fields: [ventaId], references: [id])
  createdAt   DateTime        @default(now())

  @@index([productoId])
  @@index([tipo])
  @@map("movimientos_inventario")
}

// ---------------------------------------------------------------------------
// Ventas y facturación
// ---------------------------------------------------------------------------

model Venta {
  id              Int             @id @default(autoincrement())
  clienteId       Int?
  cliente         Cliente?        @relation(fields: [clienteId], references: [id])
  usuarioId       Int?
  usuario         Usuario?        @relation(fields: [usuarioId], references: [id])
  subtotal        Float
  descuento       Float           @default(0)
  iva             Float
  total           Float
  metodoPago      String // EFECTIVO | TARJETA | TRANSFERENCIA | MIXTO
  montoEfectivo   Float?
  montoTarjeta    Float?
  montoTransferencia Float?
  estado          String          @default("COMPLETADA") // COMPLETADA | ANULADA
  notas           String?
  detalle         DetalleVenta[]
  movimientos     MovimientoInventario[]
  factura         Factura?
  createdAt       DateTime        @default(now())

  @@index([createdAt])
  @@index([clienteId])
  @@map("ventas")
}

model DetalleVenta {
  id            Int      @id @default(autoincrement())
  ventaId       Int
  venta         Venta    @relation(fields: [ventaId], references: [id])
  productoId    Int
  producto      Producto @relation(fields: [productoId], references: [id])
  cantidad      Int
  precioUnitario Float
  descuento     Float    @default(0)
  subtotal      Float

  @@index([ventaId])
  @@map("detalle_venta")
}

model Factura {
  id           Int             @id @default(autoincrement())
  numero       String          @unique // ej. FAC-000001
  consecutivo  Int
  ventaId      Int             @unique
  venta        Venta           @relation(fields: [ventaId], references: [id])
  clienteId    Int?
  cliente      Cliente?        @relation(fields: [clienteId], references: [id])
  subtotal     Float
  descuento    Float
  iva          Float
  total        Float
  metodoPago   String // EFECTIVO | TARJETA | TRANSFERENCIA | MIXTO
  estado       String          @default("EMITIDA") // EMITIDA | ANULADA
  detalle      DetalleFactura[]
  fechaEmision DateTime        @default(now())

  @@index([numero])
  @@index([fechaEmision])
  @@map("facturas")
}

model DetalleFactura {
  id             Int      @id @default(autoincrement())
  facturaId      Int
  factura        Factura  @relation(fields: [facturaId], references: [id])
  productoNombre String
  productoCodigo String
  cantidad       Int
  precioUnitario Float
  descuento      Float    @default(0)
  subtotal       Float

  @@index([facturaId])
  @@map("detalle_factura")
}

// ---------------------------------------------------------------------------
// Compras a proveedores (registro contable; no afecta el stock)
// ---------------------------------------------------------------------------

model FacturaCompra {
  id               Int             @id @default(autoincrement())
  proveedorNombre  String
  numeroFactura    String? // número/referencia de la factura del proveedor
  fecha            DateTime        @default(now())
  metodoPago       String? // EFECTIVO | TARJETA | TRANSFERENCIA
  total            Float
  notas            String?
  detalle          DetalleCompra[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([fecha])
  @@index([proveedorNombre])
  @@map("facturas_compra")
}

model DetalleCompra {
  id              Int           @id @default(autoincrement())
  facturaCompraId Int
  facturaCompra   FacturaCompra @relation(fields: [facturaCompraId], references: [id])
  descripcion     String
  cantidad        Int
  valorUnitario   Float
  subtotal        Float

  @@index([facturaCompraId])
  @@map("detalle_compra")
}
